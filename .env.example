NEBIUS_API_KEY=XXX

# Object storage (local MinIO by default; see docker-compose.yaml).
# Leave S3_ENDPOINT_URL unset to disable artifact upload (pipeline still runs).
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=swe-runs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
# MLflow reads this to talk to the same S3/MinIO endpoint.
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# MLflow tracking server (docker compose). Requires `docker compose up -d`.
# Unset to fall back to the local sqlite store (sqlite:///mlflow.db).
MLFLOW_TRACKING_URI=http://localhost:5000
