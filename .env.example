NEBIUS_API_KEY=XXX

# Object storage (local MinIO by default; see docker-compose.yaml).
# Leave S3_ENDPOINT_URL unset to disable artifact upload (pipeline still runs).
# NOTE: these localhost URLs are for running the pipeline on the HOST (standalone
# Airflow / `python -m pipeline run-all`). Inside docker-compose the Airflow
# services override them with service-name URLs (http://minio:9000, http://mlflow:5000).
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=swe-runs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
# MLflow reads this to talk to the same S3/MinIO endpoint.
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# MLflow tracking server (docker compose). Requires `docker compose up -d`.
# Unset to fall back to the local sqlite store (sqlite:///mlflow.db).
MLFLOW_TRACKING_URI=http://localhost:5000

# --- docker-compose Airflow (DockerOperator) ---
# Repo path ON THE HOST. Airflow runs pipeline steps via DockerOperator, which
# launches sibling containers through the host Docker daemon; their runs/ bind
# mount is resolved against this host path. Set to the absolute repo path.
HOST_PROJECT_DIR=/absolute/path/to/this/repo
# Run Airflow containers as the host user so files written to the mounted
# logs/ (and dags/) stay owned by you. Use `id -u`.
AIRFLOW_UID=50000
# Host `docker` group gid so the mounted /var/run/docker.sock is usable inside
# the Airflow containers. Use `getent group docker | cut -d: -f3`.
DOCKER_GID=999
# Project image the DockerOperator tasks run (built from ./Dockerfile).
AIRFLOW_PROJECT_IMAGE=swe-pipeline:latest
# Optional: pin the Airflow image / docker provider / shared secrets.
# AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
# AIRFLOW_SECRET_KEY=change-me
# AIRFLOW_JWT_SECRET=change-me
